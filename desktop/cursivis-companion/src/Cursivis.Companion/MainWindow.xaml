<Window x:Class="Cursivis.Companion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MX Creative Console Demo"
        Height="552"
        Width="432"
        MinWidth="400"
        MinHeight="520"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="20"
        Top="20"
        KeyDown="MainWindow_OnKeyDown"
        PreviewMouseLeftButtonUp="MainWindow_OnPreviewMouseLeftButtonUp">
    <Border Background="{StaticResource Brush.WindowGradient}" Padding="10">
        <Border CornerRadius="24"
                BorderBrush="#30FFFFFF"
                BorderThickness="1"
                Background="#E608111A"
                Padding="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="0"
                                  Color="#99112939"
                                  Opacity="0.85" />
            </Border.Effect>
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        CornerRadius="22"
                        Background="#66131C28"
                        BorderBrush="#3AFFFFFF"
                        BorderThickness="1"
                        Padding="18,16,18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource HeadlineTextStyle}"
                                       FontSize="26"
                                       Text="MX Creative Console Demo" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SubtleTextStyle}"
                                       FontSize="13"
                                       Text="Cursivis turns selection into context, hardware into intent, and Gemini into action." />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="12,8"
                                CornerRadius="14"
                                Background="#9920122A"
                                BorderBrush="#66F562E7"
                                BorderThickness="1"
                                VerticalAlignment="Top">
                            <TextBlock Style="{StaticResource SubtleTextStyle}"
                                       FontSize="11"
                                       Foreground="#FFF0BFFF"
                                       Text="Windows-first" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        CornerRadius="22"
                        Background="#77111B27"
                        BorderBrush="#33B6D7FF"
                        BorderThickness="1"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeadlineTextStyle}"
                                       FontSize="12"
                                       Text="Interaction Mode" />
                            <TextBlock Margin="0,4,0,12"
                                       Style="{StaticResource SubtleTextStyle}"
                                       FontSize="12"
                                       Text="Smart Mode lets Gemini decide. Guided Mode opens staged options." />
                            <ComboBox x:Name="ModeCombo"
                                      Width="224"
                                      Style="{StaticResource GlassComboBoxStyle}"
                                      SelectionChanged="ModeCombo_OnSelectionChanged">
                                <ComboBoxItem Content="Smart Mode (AutoPerform)" Tag="Smart" />
                                <ComboBoxItem Content="Guided Mode (Manual)" Tag="Guided" />
                            </ComboBox>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="86"
                                Height="42"
                                Margin="18,0,0,0"
                                VerticalAlignment="Top"
                                Style="{StaticResource MutedButtonStyle}"
                                Content="Exit"
                                Click="ExitButton_OnClick" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        CornerRadius="22"
                        Background="#77111B27"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeadlineTextStyle}"
                                       FontSize="12"
                                       Text="Trigger Surface" />
                            <TextBlock Margin="0,4,0,14"
                                       Style="{StaticResource SubtleTextStyle}"
                                       FontSize="12"
                                       Text="Tap for contextual AI, hold for voice, and capture an image region on demand." />
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Columns="2"
                                     Rows="2"
                                     Margin="0,2,0,0">
                            <Button x:Name="TriggerButton"
                                    Height="54"
                                    Margin="0,0,10,10"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Content="Trigger"
                                    Click="TriggerButton_OnClick" />
                            <Button x:Name="TakeActionButton"
                                    Height="54"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource GlassButtonStyle}"
                                    Content="Take Action"
                                    Click="TakeActionButton_OnClick" />
                            <Button x:Name="LongPressButton"
                                    Height="54"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource GlassButtonStyle}"
                                    Content="Hold to Talk"
                                    PreviewMouseLeftButtonDown="LongPressButton_OnMouseDown"
                                    PreviewMouseLeftButtonUp="LongPressButton_OnMouseUp"
                                    MouseLeave="LongPressButton_OnMouseLeave" />
                            <Button x:Name="DialPressButton"
                                    Height="54"
                                    Style="{StaticResource GlassButtonStyle}"
                                    Content="Image Selection"
                                    Click="DialPressButton_OnClick" />
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,14,0,0"
                        CornerRadius="22"
                        Background="#77111B27"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource HeadlineTextStyle}"
                                   FontSize="12"
                                   Text="Action Ring Dial" />
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock Style="{StaticResource SubtleTextStyle}"
                                       FontSize="12"
                                       Text="Rotate through candidate actions. Press the dial to execute the highlighted action." />
                            <Slider x:Name="DialSlider"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource GlassSliderStyle}"
                                    Minimum="-10"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="DialSlider_OnValueChanged" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Margin="0,14,0,0"
                        CornerRadius="20"
                        Background="#56111B27"
                        BorderBrush="#28FFFFFF"
                        BorderThickness="1"
                        Padding="14,12">
                    <TextBlock Grid.Row="4"
                               Style="{StaticResource SubtleTextStyle}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Hotkeys: Ctrl+Alt+Space = Trigger   |   Ctrl+Alt+A = Take Action   |   Ctrl+Alt+V = Voice" />
                </Border>

                <Border Grid.Row="6"
                        Margin="0,14,0,0"
                        CornerRadius="22"
                        Background="#7A101822"
                        BorderBrush="#66B6D7FF"
                        BorderThickness="1"
                        Padding="16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="0"
                                          Color="#4D5EEBFF"
                                          Opacity="0.35" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock x:Name="SelectedActionText"
                                   Style="{StaticResource HeadlineTextStyle}"
                                   FontSize="16"
                                   Text="Selected action: Summarize" />
                        <TextBlock x:Name="StatusText"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource SubtleTextStyle}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Text="Status: Ready. Press Trigger for text flow." />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
