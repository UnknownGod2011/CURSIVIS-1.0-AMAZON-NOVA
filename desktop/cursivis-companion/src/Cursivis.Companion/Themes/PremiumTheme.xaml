<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.SurfaceDeep">#FF081019</Color>
    <Color x:Key="Color.SurfaceMid">#FF111D29</Color>
    <Color x:Key="Color.SurfaceHigh">#FF172737</Color>
    <Color x:Key="Color.SurfaceGlass">#CC0F1824</Color>
    <Color x:Key="Color.StrokeSoft">#33FFFFFF</Color>
    <Color x:Key="Color.StrokeStrong">#66B6D7FF</Color>
    <Color x:Key="Color.Cyan">#FF5EEBFF</Color>
    <Color x:Key="Color.Magenta">#FFF562E7</Color>
    <Color x:Key="Color.Gold">#FFFFD36A</Color>
    <Color x:Key="Color.TextMain">#FFF7FBFF</Color>
    <Color x:Key="Color.TextMuted">#FF9DB6C9</Color>
    <Color x:Key="Color.TextSoft">#FF7F97AA</Color>

    <SolidColorBrush x:Key="Brush.SurfaceDeep" Color="{StaticResource Color.SurfaceDeep}" />
    <SolidColorBrush x:Key="Brush.SurfaceMid" Color="{StaticResource Color.SurfaceMid}" />
    <SolidColorBrush x:Key="Brush.SurfaceHigh" Color="{StaticResource Color.SurfaceHigh}" />
    <SolidColorBrush x:Key="Brush.SurfaceGlass" Color="{StaticResource Color.SurfaceGlass}" />
    <SolidColorBrush x:Key="Brush.StrokeSoft" Color="{StaticResource Color.StrokeSoft}" />
    <SolidColorBrush x:Key="Brush.StrokeStrong" Color="{StaticResource Color.StrokeStrong}" />
    <SolidColorBrush x:Key="Brush.TextMain" Color="{StaticResource Color.TextMain}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.TextSoft" Color="{StaticResource Color.TextSoft}" />
    <SolidColorBrush x:Key="Brush.Cyan" Color="{StaticResource Color.Cyan}" />
    <SolidColorBrush x:Key="Brush.Magenta" Color="{StaticResource Color.Magenta}" />
    <SolidColorBrush x:Key="Brush.Gold" Color="{StaticResource Color.Gold}" />

    <LinearGradientBrush x:Key="Brush.WindowGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF06111C" Offset="0" />
        <GradientStop Color="#FF0B1824" Offset="0.45" />
        <GradientStop Color="#FF111F2E" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.CardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#DD0A121C" Offset="0" />
        <GradientStop Color="#D8152130" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.PrimaryButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0D2033" Offset="0" />
        <GradientStop Color="#FF17324E" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.AccentButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF3F1054" Offset="0" />
        <GradientStop Color="#FF112C4B" Offset="0.55" />
        <GradientStop Color="#FF123844" Offset="1" />
    </LinearGradientBrush>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMain}" />
    </Style>

    <Style x:Key="HeadlineTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMain}" />
    </Style>

    <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    </Style>

    <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMain}" />
        <Setter Property="Background" Value="#66121B25" />
        <Setter Property="BorderBrush" Value="#66B6D7FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CaretBrush" Value="{StaticResource Brush.Cyan}" />
    </Style>

    <Style x:Key="GlassComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMain}" />
        <Setter Property="Background" Value="#8C101A24" />
        <Setter Property="BorderBrush" Value="#55B6D7FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="ComboRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="12,6,8,6"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <ToggleButton Grid.Column="1"
                                              Focusable="False"
                                              ClickMode="Press"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <Path Width="10"
                                          Height="6"
                                          Stretch="Fill"
                                          Fill="{TemplateBinding Foreground}"
                                          Data="M0,0 L5,6 L10,0 Z" />
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <Popup Name="Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Fade">
                            <Border Margin="0,8,0,0"
                                    Background="#F0141E29"
                                    BorderBrush="#66B6D7FF"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="8">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#CC5EEBFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMain}" />
        <Setter Property="Background" Value="#D9121E2A" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#FF183349" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#FF214A67" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GlassListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMain}" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="GlassListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Outer"
                            CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="#33B6D7FF"
                            Background="#7A0F1721"
                            Padding="14,12">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="#CC5EEBFF" />
                            <Setter TargetName="Outer" Property="Background" Value="#CC11253A" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="#A3142332" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMain}" />
        <Setter Property="Background" Value="{StaticResource Brush.PrimaryButtonGradient}" />
        <Setter Property="BorderBrush" Value="#558ED9FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform />
                        </Grid.RenderTransform>

                        <Border x:Name="OuterBorder"
                                CornerRadius="16"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Color="#4D62E7FF"
                                                  Opacity="0.45" />
                            </Border.Effect>
                        </Border>

                        <Border x:Name="InnerBorder"
                                Margin="1"
                                CornerRadius="15"
                                BorderBrush="#2FFFFFFF"
                                BorderThickness="1"
                                Opacity="0.65" />

                        <Rectangle x:Name="Sheen"
                                   RadiusX="16"
                                   RadiusY="16"
                                   Opacity="0"
                                   IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00FFFFFF" Offset="0" />
                                    <GradientStop Color="#55FFFFFF" Offset="0.5" />
                                    <GradientStop Color="#00FFFFFF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                            <Rectangle.RenderTransform>
                                <TranslateTransform x:Name="SheenTransform" X="-220" />
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#CC5EEBFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.92" />
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#CCF562E7" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Sheen"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:0.15"
                                                     AutoReverse="True" />
                                    <DoubleAnimation Storyboard.TargetName="SheenTransform"
                                                     Storyboard.TargetProperty="X"
                                                     From="-220"
                                                     To="240"
                                                     Duration="0:0:0.72">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1.02"
                                                     Duration="0:0:0.14" />
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1.02"
                                                     Duration="0:0:0.14" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1"
                                                     Duration="0:0:0.18" />
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1"
                                                     Duration="0:0:0.18" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Brush.AccentButtonGradient}" />
        <Setter Property="BorderBrush" Value="#88F562E7" />
    </Style>

    <Style x:Key="MutedButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
        <Setter Property="Background" Value="#A1111A27" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
    </Style>

    <Style x:Key="GlassSliderStyle" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource Brush.Cyan}" />
        <Setter Property="Background" Value="#55212F3E" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style x:Key="ThinScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Opacity" Value="0.92" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
</ResourceDictionary>
