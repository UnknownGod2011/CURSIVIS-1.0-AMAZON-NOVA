<Window x:Class="Cursivis.Companion.Views.ResultPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        Height="352"
        ShowInTaskbar="False"
        Topmost="True"
        Width="620"
        MinWidth="420"
        MinHeight="260"
        WindowStyle="None">
    <Border x:Name="RootCard"
            CornerRadius="24"
            Background="#E509111A"
            BorderBrush="#4CB6D7FF"
            BorderThickness="1"
            Padding="16">
        <Border.RenderTransform>
            <TranslateTransform x:Name="PanelTranslateTransform" Y="14" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="32"
                              ShadowDepth="0"
                              Color="#B3000000"
                              Opacity="0.86" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Rectangle Height="1"
                       VerticalAlignment="Top"
                       Fill="#33FFFFFF" />

            <Border x:Name="DragHeader"
                    Grid.Row="0"
                    Cursor="SizeAll"
                    Background="#69111B27"
                    CornerRadius="18"
                    Padding="12,10"
                    MouseLeftButtonDown="DragHeader_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="TitleText"
                                   Style="{StaticResource HeadlineTextStyle}"
                                   FontSize="19"
                                   Text="AI Result" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource SubtleTextStyle}"
                                   FontSize="11"
                                   Text="Drag this panel anywhere. Clipboard is updated automatically." />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="10,6"
                            CornerRadius="13"
                            Background="#8C1E1227"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <TextBlock Foreground="#FFF4D6FF"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="10"
                                   Text="DRAG" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,10"
                    Padding="12,8"
                    CornerRadius="16"
                    Background="#80111F2D"
                    BorderBrush="#33F562E7"
                    BorderThickness="1"
                    HorizontalAlignment="Left">
                <TextBlock x:Name="ActionText"
                           Style="{StaticResource HeadlineTextStyle}"
                           FontSize="12"
                           Foreground="#FFF0BEFF"
                           Text="Action: Summarize" />
            </Border>

            <Border Grid.Row="2"
                    CornerRadius="20"
                    Background="#A50B131C"
                    BorderBrush="#2CFFFFFF"
                    BorderThickness="1"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SubtleTextStyle}"
                               FontSize="11"
                               Text="Generated output" />
                    <ScrollViewer x:Name="ResultScrollViewer"
                                  Grid.Row="1"
                                  Margin="0,10,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}" />
                        </ScrollViewer.Resources>
                    <TextBlock x:Name="ResultBodyText"
                               TextWrapping="Wrap"
                               Foreground="#FFF7FBFF"
                               FontSize="14"
                               FontFamily="Bahnschrift"
                               LineHeight="23" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Row="3"
                  Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Thumb Grid.Column="0"
                       Width="18"
                       Height="18"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Cursor="SizeNWSE"
                       DragDelta="ResizeThumb_OnDragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Grid Width="18" Height="18">
                                <Path Stroke="#66FFFFFF"
                                      StrokeThickness="1.2"
                                      Data="M2,16 L16,2 M8,16 L16,8 M12,16 L16,12" />
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="TakeActionButton"
                            Width="116"
                            Height="38"
                            Margin="0,0,8,0"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="Take Action"
                            Click="TakeActionButton_OnClick" />
                    <Button x:Name="UndoButton"
                            Width="78"
                            Height="38"
                            Margin="0,0,8,0"
                            Style="{StaticResource MutedButtonStyle}"
                            Content="Undo"
                            IsEnabled="False"
                            Click="UndoButton_OnClick" />
                    <Button x:Name="CopyButton"
                            Width="78"
                            Height="38"
                            Margin="0,0,8,0"
                            Style="{StaticResource GlassButtonStyle}"
                            Content="Copy"
                            Click="CopyButton_OnClick" />
                    <Button x:Name="InsertButton"
                            Width="78"
                            Height="38"
                            Margin="0,0,8,0"
                            Style="{StaticResource GlassButtonStyle}"
                            Content="Insert"
                            Click="InsertButton_OnClick" />
                    <Button x:Name="MoreOptionsButton"
                            Width="116"
                            Height="38"
                            Style="{StaticResource GlassButtonStyle}"
                            Content="More Options"
                            Click="MoreOptionsButton_OnClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
