# AWS credentials — use IAM user keys OR an IAM role (e.g. on EC2/ECS/Lambda)
AWS_ACCESS_KEY_ID=replace-with-your-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-your-secret-access-key
AWS_REGION=us-east-1

# Nova Act API key — get from https://nova.amazon.com/act
NOVA_ACT_API_KEY=replace-with-your-nova-act-api-key

# Model overrides (optional)
NOVA_LITE_MODEL=us.amazon.nova-2-lite-v1:0
NOVA_SONIC_MODEL=amazon.nova-2-sonic-v1:0

# Server
PORT=8080

# Grounding / web search toggle (true|false)
CURSIVIS_ENABLE_GROUNDING=true
