# ── AWS credentials ────────────────────────────────────────────────────────────
# Use IAM user keys OR an IAM role (EC2/ECS/Lambda instance profile)
AWS_ACCESS_KEY_ID=replace-with-your-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-your-secret-access-key
AWS_REGION=eu-north-1

# ── Bedrock model IDs ──────────────────────────────────────────────────────────
# Swap these to cross-region inference profile IDs if needed (e.g. us.amazon.nova-lite-v1:0)
BEDROCK_TEXT_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_VOICE_MODEL_ID=amazon.nova-2-sonic-v1:0
BEDROCK_EMBEDDING_MODEL_ID=

# ── Optional: Nova Sonic voice ID ─────────────────────────────────────────────
NOVA_SONIC_VOICE_ID=matthew

# ── Optional: bearer token for Bedrock API key auth (not used by default) ─────
# AWS_BEARER_TOKEN_BEDROCK=replace-if-needed

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080

# ── Feature flags ──────────────────────────────────────────────────────────────
CURSIVIS_ENABLE_GROUNDING=true
CURSIVIS_LIVE_VOICE_PATH=/live
